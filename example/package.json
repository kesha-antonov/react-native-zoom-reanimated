{
  "name": "example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "npx expo start --dev-client --clear",
    "start:android": "npx expo start --android --dev-client --clear",
    "start:ios": "npx expo start --ios --dev-client --clear",
    "start:web": "npx expo start --web --clear",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "fresh": "yarn start --reset-cache",
    "installDevBuild:ios": "npx expo run:ios",
    "installDevBuild:android": "npx expo run:android",
    "rebuildNativeDeps": "npx expo prebuild",
    "rebuildNativeDeps:clean": "npx expo prebuild --clean",
    "freshAndroid": "npx expo prebuild --clean && expo run:android",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "^56.0.0",
    "expo-image": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-worklets": "0.8.3",
    "react-native-zoom-reanimated": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.2",
    "@react-native-community/cli": "^20.1.0",
    "@react-native/jest-preset": "^0.85.3",
    "@react-native/metro-config": "^0.85.3",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "^3.8.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.53.0"
  },
  "engines": {
    "node": ">=20"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
